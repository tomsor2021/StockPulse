{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit Debug",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "app.py",
                "--server.port",
                "8501"
            ],
            "cwd": "c:/Users/Administrator/Documents/StockPulse",
            "env": {},
            "console": "integratedTerminal",
            "justMyCode": false,
            "stopOnEntry": false,
            "redirectOutput": true,
            "showReturnValue": true,
            "purpose": [
                "debug-in-terminal"
            ]
        }
    ]
}